{
  "name": "@hkyhy/marsun-components-core",
  "version": "0.1.23",
  "description": "Marsun pure UI component library",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hkyhy/MARSUN_components-core.git"
  },
  "bugs": {
    "url": "https://github.com/hkyhy/MARSUN_components-core/issues"
  },
  "homepage": "https://hkyhy.github.io/MARSUN_components-core/",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./theme": {
      "import": "./dist/theme/index.js",
      "types": "./dist/theme/index.d.ts"
    },
    "./styles": "./dist/styles/global.css",
    "./tokens": "./dist/theme/tokens.css"
  },
  "sideEffects": [
    "**/*.css",
    "**/*.scss"
  ],
  "files": [
    "dist"
  ],
  "scripts": {
    "predev": "node dev/scripts/collect-examples.mjs",
    "dev": "vite --config vite.config.dev.ts",
    "version:check": "node scripts/version-check.mjs",
    "version:check:apply": "node scripts/version-check.mjs --apply",
    "version:sync": "node scripts/version-check.mjs --apply-published",
    "build": "tsc -p tsconfig.build.json && vite build --config vite.config.lib.ts && node -e \"const fs=require('fs');const path=require('path');fs.mkdirSync('dist/styles',{recursive:true});fs.mkdirSync('dist/theme',{recursive:true});fs.copyFileSync('dist/marsun-components-core.css','dist/styles/global.css');fs.copyFileSync(path.join('src','theme','tokens.css'),'dist/theme/tokens.css');\"",
    "prepublishOnly": "npm run build",
    "prebuild:showcase": "node dev/scripts/collect-examples.mjs",
    "build:showcase": "vite build --config vite.config.dev.ts",
    "postbuild:showcase": "node dev/scripts/postbuild-showcase.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"{src,dev}/**/*.{ts,tsx,scss,css,json}\"",
    "lint-staged": "lint-staged",
    "prepare": "husky",
    "preview": "vite preview --config vite.config.dev.ts",
    "preview:showcase": "vite preview --config vite.config.dev.ts --outDir dist-showcase",
    "collect-examples": "node dev/scripts/collect-examples.mjs",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "lint-staged": {
    "*.{js,ts,css,less,scss,vue,jsx,tsx,md,json}": [
      "prettier --write"
    ]
  },
  "peerDependencies": {
    "antd": "^6.0.0",
    "axios": "^1.7.0",
    "dayjs": "^1.11.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^6.28.0 || ^7.0.0"
  },
  "dependencies": {
    "@js-preview/excel": "^1.7.14",
    "@kne/button-group": "^0.1.24",
    "ahooks": "^3.8.1",
    "classnames": "^2.5.1",
    "dayjs": "^1.11.13",
    "docx-preview": "^0.3.7",
    "lucide-react": "^1.18.0",
    "mermaid": "^11.15.0",
    "pptx-preview": "^1.0.7",
    "prism-react-renderer": "^2.4.1",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.14.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "antd": "^6.0.0",
    "axios": "^1.7.7",
    "dayjs": "^1.11.13",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.14",
    "globals": "^15.12.0",
    "happy-dom": "^20.9.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "prettier": "^3.8.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.0.0",
    "sass": "^1.101.0",
    "typescript": "~5.6.2",
    "typescript-eslint": "^8.14.0",
    "vite": "^6.0.1",
    "vite-plugin-dts": "^4.5.0",
    "vitest": "^4.1.7"
  }
}
