      "sourcePath": "@/components/Filter/examples/CommonFilterDemo.tsx",
      "block": true
    },
    {
      "title": "单选筛选器",
      "description": "FilterSelect 基础用法与可搜索模式",
      "component": "@/components/Filter/examples/FilterSelectDemo",
      "sourcePath": "@/components/Filter/examples/FilterSelectDemo/index.tsx"
    },
    {
      "title": "输入框筛选器",
