      "component": "@/components/Filter/examples/FilterDateRangeDemo",
      "sourcePath": "@/components/Filter/examples/FilterDateRangeDemo.tsx"
    },
    {
      "title": "数字范围筛选器",
      "description": "FilterNumberRange 数值区间选择，支持单位后缀",
      "component": "@/components/Filter/examples/FilterNumberRangeDemo",
      "sourcePath": "@/components/Filter/examples/FilterNumberRangeDemo.tsx"
    },
    {
      "title": "树形选择筛选器",
